’Щ@b3ece5b7b26254595ed5b55bc375b08ced2f3614e950214a1179ff5f37e60ee7ЪWTitle: title: polars selector integer
Path: Examples
Content:
Select all integer columns
```Fenced(Borrowed("nu"))
> {
        "foo": ["x", "y"],
        "bar": [123, 456],
        "baz": [2.0, 5.5],
        "zap": [0, 0],
    } |
    polars into-df --as-columns |
    polars select (polars selector integer) |
    polars sort-by bar zap |
    polars collect
