’Щ@1e0b7e948be426e442cbe5cfce34a7c7f981d1da6e86f9d4bd5df44a093fede4ЪµTitle: title: polars selector numeric
Path: Examples
Content:
Select all numeric columns
```Fenced(Borrowed("nu"))
> {
        "foo": ["x", "y"],
        "bar": [123, 456],
        "baz": [2.0, 5.5],
        "zap": [0, 0],
    } |
    polars into-df --as-columns |
    polars select (polars selector numeric) |
    polars sort-by bar baz zap |
    polars collect
