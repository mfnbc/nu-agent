—Щbarchive/external_nushell_repo_backup/nushell.github.io/blog/2023-08-23-happy-birthday-nushell-4.mdЩ@31d1695c87e59eeb3d965623a5dd2f3683965a242f34c34950fa5503ebc50292Щ%title: Celebrating 4 years of Nushell‘Щ Crossplatform symlinks (Kubouch)Ъ="Here is my favorite: Cross-platform symlink:"
```Fenced(Borrowed("nushell"))
# Create a symlink
export def symlink [
    existing: path   # The existing file
    link_name: path  # The name of the symlink
] {
    let existing = ($existing | path expand -s)
    let link_name = ($link_name | path expand)

    if $nu.os-info.family == 'windows' {
        if ($existing | path type) == 'dir' {
            mklink /D $link_name $existing
        } else {
            mklink $link_name $existing
        }
    } else {
        ln -s $existing $link_name | ignore
    }
}

```
’ђђЪљTitle: title: Celebrating 4 years of Nushell
Path: Crossplatform symlinks (Kubouch)
Content:
"Here is my favorite: Cross-platform symlink:"
```Fenced(Borrowed("nushell"))
# Create a symlink
export def symlink [
    existing: path   # The existing file
    link_name: path  # The name of the symlink
] {
    let existing = ($existing | path expand -s)
    let link_name = ($link_name | path expand)

    if $nu.os-info.family == 'windows' {
        if ($existing | path type) == 'dir' {
            mklink /D $link_name $existing
        } else {
            mklink $link_name $existing
        }
    } else {
        ln -s $existing $link_name | ignore
    }
}

```
—Щbarchive/external_nushell_repo_backup/nushell.github.io/blog/2023-08-23-happy-birthday-nushell-4.mdЩ@001e3260887829e7fbda3498cb0e966aec4c96f016b076ef09e9ad84cb407937Щ%title: Celebrating 4 years of Nushell‘Щ+Giving your hex values some color (fdncred)ЩРadd 
``string: {|x| if $x =~ '^#[a-fA-F\d]+' { $x } else { 'white' } }``
 to your 
``$env.config.color_config``
 and you'll get:
screenshot showing each hex value colored to match the color of that hex value
