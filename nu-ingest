#!/usr/bin/env nu
use ./nu-ingest.nu *

export def main [
  path: string
  --out-dir: string = "build/nu-ingest"
  --source: string = ""
  --attach-code-blocks
] {
  if $attach_code_blocks {
    ingest $path --out-dir $out_dir --source $source --attach-code-blocks
  } else {
    ingest $path --out-dir $out_dir --source $source
  }
}
