#!/home/michael/.cargo/bin/nu
use ./mod.nu *

export def main [
  --prompt: string = ""
  --contract: string = ""
] {
  if ($prompt | str length) == 0 {
    error make { msg: "Missing required --prompt argument. Example: nu-agent --prompt \"How do I stream records to an HTTP endpoint?\"" }
  }
  let contract_path = if ($contract | str length) > 0 {
    $contract
  } else {
    ($env.FILE_PWD | path join "contracts" "architect.toml")
  }
  print --stderr "Calling Nushell Data Architect. May take several minutes."
  consult $contract_path $prompt
}
