#!/usr/bin/env python3
"""
Convert a newline-delimited JSON file into a single MessagePack array.

Usage: ./scripts/convert_jsonl_to_msgpack.py <input-file> [<output-file>]

If the input file already appears to be binary MessagePack, the script
will skip conversion.

The script prefers to overwrite the input file when only one path is
provided (it writes to a temporary file and renames into place).
"""
import sys
import json
from pathlib import Path


def looks_textual(path: Path) -> bool:
    # Heuristic: read the first 1024 bytes and see if it's valid UTF-8 and
    # starts with a JSON-friendly character ('{','[','"') or a '{' on first
    # non-whitespace char. If so, treat as textual JSON/JSONL.
    try:
        with path.open('rb') as f:
            sample = f.read(1024)
    except Exception:
        return False

    try:
        s = sample.decode('utf-8')
    except Exception:
        return False

    s = s.lstrip()
    return bool(s) and s[0] in '{["'


def convert(input_path: Path, output_path: Path):
    try:
        import msgpack
    except Exception as e:
        print("ERROR: Python module 'msgpack' is required. Install with: pip install msgpack", file=sys.stderr)
        raise

    items = []
    # Read as newline-delimited JSON records. Also allow the whole file to be
    # a single JSON array.
    text = input_path.read_text(encoding='utf-8')
    text_stripped = text.lstrip()
    if text_stripped.startswith('['):
        # Whole-file JSON array
        items = json.loads(text)
    else:
        # JSONL: parse per-line non-empty lines
        for ln in text.splitlines():
            ln = ln.strip()
            if not ln:
                continue
            items.append(json.loads(ln))

    packed = msgpack.packb(items, use_bin_type=True)
    output_path.write_bytes(packed)


def main(argv):
    if len(argv) < 2:
        print(__doc__)
        return 2

    inp = Path(argv[1])
    if not inp.exists():
        print(f"Input file not found: {inp}", file=sys.stderr)
        return 2

    out = Path(argv[2]) if len(argv) > 2 else inp.with_suffix(inp.suffix + '.out')

    if not looks_textual(inp):
        print(f"Input {inp} does not look like textual JSON/JSONL; skipping conversion.")
        # If output path differs, copy bytes; otherwise do nothing
        if out != inp:
            out.write_bytes(inp.read_bytes())
        return 0

    convert(inp, out)

    # If output was meant to replace input (no explicit output arg), move it into place
    if len(argv) < 3:
        tmp = out
        final = inp
        tmp.replace(final)
        print(f"Converted and replaced {inp}")
    else:
        print(f"Converted {inp} -> {out}")

    return 0


if __name__ == '__main__':
    raise SystemExit(main(sys.argv))
